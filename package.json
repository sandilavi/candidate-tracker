{
  "name": "candidate-tracker",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build:shared": "npm run build --workspace=packages/shared",
    "dev": "npx concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build": "npm run build:shared"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
