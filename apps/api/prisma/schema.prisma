generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Candidate {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  email        String    @unique
  phone        String?   @unique
  location     String?
  linkedin_url String?   @unique
  notes        String?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime? // For soft deletes

  applications Application[]

  @@map("candidates")
}

model Application {
  id                 String   @id @default(uuid()) @db.Uuid
  candidate_id       String   @db.Uuid
  job_title          String
  company            String
  status             String   // Enforced via Zod at app level: applied, screening, interview, offer, hired, rejected
  applied_at         DateTime
  salary_expectation Int?
  source             String?
  notes              String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  candidate Candidate @relation(fields: [candidate_id], references: [id])

  @@map("applications")
}
